<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Light 主题 Token -->
    
    <!-- 窗口背景 -->
    <Color x:Key="BgColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="Bg" Color="{StaticResource BgColor}"/>
    
    <!-- 悬浮/输入区 -->
    <Color x:Key="SurfaceColor">#F5F5F7</Color>
    <SolidColorBrush x:Key="Surface" Color="{StaticResource SurfaceColor}"/>
    
    <!-- 细描边 (8% 黑色) -->
    <Color x:Key="BorderColor">#14000000</Color>
    <SolidColorBrush x:Key="Border" Color="{StaticResource BorderColor}"/>
    
    <!-- 主文本 -->
    <Color x:Key="TextColor">#1C1C1E</Color>
    <SolidColorBrush x:Key="Text" Color="{StaticResource TextColor}"/>
    
    <!-- 次要文本/placeholder/时间戳 -->
    <Color x:Key="TextSecondaryColor">#8E8E93</Color>
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}"/>
    
    <!-- 唯一强调色 (光标、选中、默认标记、链接) -->
    <Color x:Key="AccentColor">#0A84FF</Color>
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}"/>
    
    <!-- 强调色弱化背景 (12% 透明度) -->
    <Color x:Key="AccentMutedColor">#1F0A84FF</Color>
    <SolidColorBrush x:Key="AccentMuted" Color="{StaticResource AccentMutedColor}"/>
    
</ResourceDictionary>