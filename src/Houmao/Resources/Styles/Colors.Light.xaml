<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- 浅色主题颜色 -->
    
    <!-- 窗口背景 -->
    <Color x:Key="WindowBackgroundColor">#F5F5F5</Color>
    <SolidColorBrush x:Key="WindowBackground" Color="{StaticResource WindowBackgroundColor}"/>
    
    <!-- 窗口边框 -->
    <Color x:Key="WindowBorderColor">#E0E0E0</Color>
    <SolidColorBrush x:Key="WindowBorder" Color="{StaticResource WindowBorderColor}"/>
    
    <!-- 标题栏 -->
    <Color x:Key="TitleBarBackgroundColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="TitleBarBackground" Color="{StaticResource TitleBarBackgroundColor}"/>
    
    <Color x:Key="TitleBarTextColor">#333333</Color>
    <SolidColorBrush x:Key="TitleBarText" Color="{StaticResource TitleBarTextColor}"/>
    
    <!-- 输入框 -->
    <Color x:Key="InputBackgroundColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="InputBackground" Color="{StaticResource InputBackgroundColor}"/>
    
    <Color x:Key="InputBorderColor">#E0E0E0</Color>
    <SolidColorBrush x:Key="InputBorder" Color="{StaticResource InputBorderColor}"/>
    
    <Color x:Key="InputTextColor">#333333</Color>
    <SolidColorBrush x:Key="InputText" Color="{StaticResource InputTextColor}"/>
    
    <Color x:Key="InputPlaceholderColor">#999999</Color>
    <SolidColorBrush x:Key="InputPlaceholder" Color="{StaticResource InputPlaceholderColor}"/>
    
    <!-- 状态栏 -->
    <Color x:Key="StatusBarBackgroundColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="StatusBarBackground" Color="{StaticResource StatusBarBackgroundColor}"/>
    
    <Color x:Key="StatusBarTextColor">#666666</Color>
    <SolidColorBrush x:Key="StatusBarText" Color="{StaticResource StatusBarTextColor}"/>
    
    <!-- 附件 -->
    <Color x:Key="AttachmentBackgroundColor">#E3F2FD</Color>
    <SolidColorBrush x:Key="AttachmentBackground" Color="{StaticResource AttachmentBackgroundColor}"/>
    
    <Color x:Key="AttachmentTextColor">#1976D2</Color>
    <SolidColorBrush x:Key="AttachmentText" Color="{StaticResource AttachmentTextColor}"/>
    
    <!-- 消息气泡 -->
    <Color x:Key="UserMessageBackgroundColor">#E3F2FD</Color>
    <SolidColorBrush x:Key="UserMessageBackground" Color="{StaticResource UserMessageBackgroundColor}"/>
    
    <Color x:Key="AssistantMessageBackgroundColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="AssistantMessageBackground" Color="{StaticResource AssistantMessageBackgroundColor}"/>
    
    <Color x:Key="MessageTextColor">#333333</Color>
    <SolidColorBrush x:Key="MessageText" Color="{StaticResource MessageTextColor}"/>
    
    <!-- 按钮 -->
    <Color x:Key="ButtonBackgroundColor">#1976D2</Color>
    <SolidColorBrush x:Key="ButtonBackground" Color="{StaticResource ButtonBackgroundColor}"/>
    
    <Color x:Key="ButtonTextColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="ButtonText" Color="{StaticResource ButtonTextColor}"/>
    
    <Color x:Key="ButtonHoverBackgroundColor">#1565C0</Color>
    <SolidColorBrush x:Key="ButtonHoverBackground" Color="{StaticResource ButtonHoverBackgroundColor}"/>
    
    <Color x:Key="ButtonPressedBackgroundColor">#0D47A1</Color>
    <SolidColorBrush x:Key="ButtonPressedBackground" Color="{StaticResource ButtonPressedBackgroundColor}"/>
    
    <!-- 窗口按钮 -->
    <Color x:Key="WindowButtonBackgroundColor">Transparent</Color>
    <SolidColorBrush x:Key="WindowButtonBackground" Color="{StaticResource WindowButtonBackgroundColor}"/>
    
    <Color x:Key="WindowButtonTextColor">#666666</Color>
    <SolidColorBrush x:Key="WindowButtonText" Color="{StaticResource WindowButtonTextColor}"/>
    
    <Color x:Key="WindowButtonHoverBackgroundColor">#E0E0E0</Color>
    <SolidColorBrush x:Key="WindowButtonHoverBackground" Color="{StaticResource WindowButtonHoverBackgroundColor}"/>
    
    <Color x:Key="WindowButtonPressedBackgroundColor">#BDBDBD</Color>
    <SolidColorBrush x:Key="WindowButtonPressedBackground" Color="{StaticResource WindowButtonPressedBackgroundColor}"/>
    
    <!-- 分隔线 -->
    <Color x:Key="SeparatorColor">#E0E0E0</Color>
    <SolidColorBrush x:Key="Separator" Color="{StaticResource SeparatorColor}"/>
    
    <!-- 滚动条 -->
    <Color x:Key="ScrollBarBackgroundColor">#F5F5F5</Color>
    <SolidColorBrush x:Key="ScrollBarBackground" Color="{StaticResource ScrollBarBackgroundColor}"/>
    
    <Color x:Key="ScrollBarThumbColor">#BDBDBD</Color>
    <SolidColorBrush x:Key="ScrollBarThumb" Color="{StaticResource ScrollBarThumbColor}"/>
    
    <Color x:Key="ScrollBarThumbHoverColor">#9E9E9E</Color>
    <SolidColorBrush x:Key="ScrollBarThumbHover" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    
    <!-- 代码块 -->
    <Color x:Key="CodeBlockBackgroundColor">#F5F5F5</Color>
    <SolidColorBrush x:Key="CodeBlockBackground" Color="{StaticResource CodeBlockBackgroundColor}"/>
    
    <Color x:Key="CodeBlockTextColor">#333333</Color>
    <SolidColorBrush x:Key="CodeBlockText" Color="{StaticResource CodeBlockTextColor}"/>
    
    <Color x:Key="CodeBlockBorderColor">#E0E0E0</Color>
    <SolidColorBrush x:Key="CodeBlockBorder" Color="{StaticResource CodeBlockBorderColor}"/>
    
</ResourceDictionary>