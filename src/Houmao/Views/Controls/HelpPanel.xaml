<UserControl x:Class="Houmao.Views.Controls.HelpPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource WindowBackground}">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
        <StackPanel>
            <!-- 标题 -->
            <TextBlock Text="Help" 
                       FontSize="18" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TitleBarText}"
                       Margin="0,0,0,16"/>
            
            <!-- 快捷键部分 -->
            <TextBlock Text="Keyboard Shortcuts" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MessageText}"
                       Margin="0,0,0,8"/>
            
            <Border Background="{DynamicResource StatusBarBackground}"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Double Alt" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Show/Hide window"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Esc" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Hide window"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ctrl+W" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Hide window"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ctrl+," FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Open settings"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ctrl+K" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Clear conversation"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="↑ / ↓" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Command history"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- 命令部分 -->
            <TextBlock Text="Commands" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MessageText}"
                       Margin="0,0,0,8"/>
            
            <Border Background="{DynamicResource StatusBarBackground}"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="b" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Toggle history panel"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="h" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Toggle help panel"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="@provider msg" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Use specific provider"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="@model msg" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Use specific model"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Provider 列表 -->
            <TextBlock Text="Configured Providers" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MessageText}"
                       Margin="0,0,0,8"/>
            
            <Border Background="{DynamicResource StatusBarBackground}"
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,0,0,16">
                <ItemsControl ItemsSource="{Binding Providers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" (default)" 
                                               Foreground="{DynamicResource ButtonBackground}"
                                               Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ApiUrl}" 
                                           Foreground="{DynamicResource StatusBarText}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding ModelsText}" 
                                           Foreground="{DynamicResource StatusBarText}"
                                           FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>