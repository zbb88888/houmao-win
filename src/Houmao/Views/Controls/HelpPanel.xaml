<UserControl x:Class="Houmao.Views.Controls.HelpPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
        <StackPanel>
            <!-- 快捷键部分 -->
            <TextBlock Text="KEYBOARD SHORTCUTS" 
                       FontSize="12" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,0,12"/>
            
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Double Alt" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Grid.Column="1" Text="Show/Hide window" Foreground="{DynamicResource TextSecondary}"/>
            </Grid>
            
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Esc" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Grid.Column="1" Text="Hide window" Foreground="{DynamicResource TextSecondary}"/>
            </Grid>
            
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Ctrl+W" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Grid.Column="1" Text="Hide window" Foreground="{DynamicResource TextSecondary}"/>
            </Grid>
            
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Ctrl+," FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Grid.Column="1" Text="Open settings" Foreground="{DynamicResource TextSecondary}"/>
            </Grid>
            
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Ctrl+K" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Grid.Column="1" Text="Clear conversation" Foreground="{DynamicResource TextSecondary}"/>
            </Grid>
            
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="↑ / ↓" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Grid.Column="1" Text="Command history" Foreground="{DynamicResource TextSecondary}"/>
            </Grid>
            
            <!-- 命令部分 -->
            <TextBlock Text="COMMANDS" 
                       FontSize="12" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,0,12"/>
            
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="b" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Grid.Column="1" Text="Toggle history panel" Foreground="{DynamicResource TextSecondary}"/>
            </Grid>
            
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="h" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Grid.Column="1" Text="Toggle help panel" Foreground="{DynamicResource TextSecondary}"/>
            </Grid>
            
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="@provider msg" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Grid.Column="1" Text="Use specific provider" Foreground="{DynamicResource TextSecondary}"/>
            </Grid>
            
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="@model msg" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Grid.Column="1" Text="Use specific model" Foreground="{DynamicResource TextSecondary}"/>
            </Grid>
            
            <!-- Provider 列表 -->
            <TextBlock Text="CONFIGURED PROVIDERS" 
                       FontSize="12" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,0,0,12"/>
            
            <ItemsControl ItemsSource="{Binding Providers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                                <TextBlock Text=" (default)" 
                                           Foreground="{DynamicResource Accent}"
                                           Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding ApiUrl}" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding ModelsText}" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>