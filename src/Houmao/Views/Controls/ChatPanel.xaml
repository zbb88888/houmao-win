<UserControl x:Class="Houmao.Views.Controls.ChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:Houmao.Views.Controls"
             mc:Ignorable="d"
             Background="Transparent">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,0">
        <ItemsControl ItemsSource="{Binding Messages}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{Binding IsUser, Converter={StaticResource UserMessageBackgroundConverter}}"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,0,0,8"
                            HorizontalAlignment="{Binding IsUser, Converter={StaticResource UserMessageAlignmentConverter}}"
                            MaxWidth="600">
                        <Grid>
                            <!-- 用户消息显示纯文本 -->
                            <TextBlock Text="{Binding Content}" 
                                       Foreground="{DynamicResource MessageText}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding IsUser, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            
                            <!-- 助手消息显示 Markdown -->
                            <views:MarkdownViewer Markdown="{Binding Content}"
                                                  Visibility="{Binding IsUser, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>