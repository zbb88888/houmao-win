<UserControl x:Class="Houmao.Views.Controls.ChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:Houmao.Views.Controls"
             mc:Ignorable="d"
             Background="Transparent">
    
    <ItemsControl ItemsSource="{Binding Messages}">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <StackPanel Margin="0,0,0,16">
                    <!-- 用户消息 -->
                    <Grid Visibility="{Binding IsUser, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Q 前缀 -->
                        <TextBlock Grid.Column="0"
                                   Text="Q"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,2,12,0"/>
                        
                        <!-- 问题内容 -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Content}" 
                                   Foreground="{DynamicResource Text}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   LineHeight="21"/>
                    </Grid>
                    
                    <!-- 助手消息 -->
                    <Grid Visibility="{Binding IsUser, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- A 前缀 -->
                        <TextBlock Grid.Column="0"
                                   Text="A"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Accent}"
                                   Margin="0,2,12,0"/>
                        
                        <!-- 回复内容 -->
                        <StackPanel Grid.Column="1">
                            <!-- 模型名标签（可选） -->
                            <TextBlock Text="{Binding ModelName}" 
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Visibility="{Binding ModelName, Converter={StaticResource NullToVisibilityConverter}}"
                                       Margin="0,0,0,4"/>
                            
                            <!-- Markdown 内容 -->
                            <views:MarkdownViewer Markdown="{Binding Content}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>