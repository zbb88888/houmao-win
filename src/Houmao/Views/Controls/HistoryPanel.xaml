<UserControl x:Class="Houmao.Views.Controls.HistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="16,12,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="HISTORY" 
                           FontSize="12" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalCount, StringFormat='  ({0} records)'}" 
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <Button Content="Refresh" 
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource ButtonStyle}"
                        FontSize="12"
                        Padding="8,4"
                        Margin="0,0,8,0"/>
                
                <Button Content="Clear all" 
                        Command="{Binding ClearAllCommand}"
                        Style="{DynamicResource ButtonStyle}"
                        FontSize="12"
                        Padding="8,4"/>
            </StackPanel>
        </Grid>
        
        <!-- 历史列表 -->
        <Border Grid.Row="1" Padding="16,0">
            <ListView ItemsSource="{Binding Records}"
                      SelectionMode="Single"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.ScrollChanged="ListView_ScrollChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="Transparent"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="0,0,0,0.5"
                                Padding="0,8,0,8"
                                Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Summary}" 
                                               Foreground="{DynamicResource Text}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="40"
                                               TextWrapping="Wrap"/>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding ApplicationName}" 
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11"
                                                   Margin="0,0,12,0"/>
                                        
                                        <TextBlock Text="{Binding TimestampDisplay}" 
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding ProviderName}" 
                                           Foreground="{DynamicResource Accent}"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
                
                <ListView.Template>
                    <ControlTemplate TargetType="ListView">
                        <Border Background="Transparent">
                            <ScrollViewer x:Name="ScrollViewer">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </ListView.Template>
            </ListView>
        </Border>
        
        <!-- 加载更多 -->
        <Border Grid.Row="2" 
                Padding="16,12"
                Visibility="{Binding HasMore, Converter={StaticResource BoolToVisibilityConverter}}">
            <Button Content="Load more" 
                    Command="{Binding LoadMoreCommand}"
                    Style="{DynamicResource ButtonStyle}"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Padding="12,6"/>
        </Border>
        
        <!-- 加载指示器 -->
        <Border Grid.Row="1" 
                Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Loading..." 
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>