<UserControl x:Class="Houmao.Views.Controls.HistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource WindowBackground}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" 
                Background="{DynamicResource StatusBarBackground}"
                Padding="12,8">
            <DockPanel>
                <TextBlock Text="History" 
                           FontSize="16" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TitleBarText}"
                           VerticalAlignment="Center"/>
                
                <StackPanel DockPanel.Dock="Right" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right">
                    <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} records'}" 
                               Foreground="{DynamicResource StatusBarText}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    
                    <Button Content="Refresh" 
                            Command="{Binding RefreshCommand}"
                            Style="{DynamicResource WindowButtonStyle}"
                            Width="60"
                            Height="24"
                            Margin="0,0,8,0"/>
                    
                    <Button Content="Clear All" 
                            Command="{Binding ClearAllCommand}"
                            Style="{DynamicResource WindowButtonStyle}"
                            Width="60"
                            Height="24"/>
                </StackPanel>
            </DockPanel>
        </Border>
        
        <!-- 历史列表 -->
        <Border Grid.Row="1" Padding="12,0">
            <ListView ItemsSource="{Binding Records}"
                      SelectionMode="Single"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.ScrollChanged="ListView_ScrollChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource StatusBarBackground}"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Summary}" 
                                               Foreground="{DynamicResource MessageText}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="40"
                                               TextWrapping="Wrap"/>
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding ApplicationName}" 
                                                   Foreground="{DynamicResource StatusBarText}"
                                                   FontSize="11"
                                                   Margin="0,0,12,0"/>
                                        
                                        <TextBlock Text="{Binding TimestampDisplay}" 
                                                   Foreground="{DynamicResource StatusBarText}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding ProviderName}" 
                                           Foreground="{DynamicResource ButtonBackground}"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
                
                <ListView.Template>
                    <ControlTemplate TargetType="ListView">
                        <Border Background="Transparent">
                            <ScrollViewer x:Name="ScrollViewer">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </ListView.Template>
            </ListView>
        </Border>
        
        <!-- 加载更多 -->
        <Border Grid.Row="2" 
                Background="{DynamicResource StatusBarBackground}"
                Padding="12,8"
                Visibility="{Binding HasMore, Converter={StaticResource BoolToVisibilityConverter}}">
            <Button Content="Load More" 
                    Command="{Binding LoadMoreCommand}"
                    Style="{DynamicResource WindowButtonStyle}"
                    HorizontalAlignment="Center"
                    Width="100"
                    Height="24"/>
        </Border>
        
        <!-- 加载指示器 -->
        <Border Grid.Row="1" 
                Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Loading..." 
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>