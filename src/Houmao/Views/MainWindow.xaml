<Window x:Class="Houmao.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Houmao.Views.Controls"
        xmlns:vm="clr-namespace:Houmao.ViewModels"
        Title="Houmao" 
        Width="680" 
        Height="Auto"
        SizeToContent="Height"
        MaxHeight="480"
        WindowStartupLocation="Manual"
        Left="200"
        Top="200"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        IsVisibleChanged="Window_IsVisibleChanged"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <!-- 主容器：毛玻璃效果 -->
    <Border CornerRadius="10"
            Background="{DynamicResource Bg}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="0.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.18" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 输入行 -->
            <Grid Grid.Row="0" Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 搜索/状态字形 -->
                <TextBlock Grid.Column="0"
                           Text="⌕"
                           FontSize="18"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                
                <!-- 输入框 -->
                <TextBox x:Name="InputTextBox"
                         Grid.Column="1"
                         Style="{DynamicResource InputStyle}"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="False"
                         KeyDown="InputTextBox_KeyDown"/>
            </Grid>
            
            <!-- 分隔线（仅在有内容时显示） -->
            <Border x:Name="Separator"
                    Grid.Row="1"
                    Height="0.5"
                    Background="{DynamicResource Border}"
                    Margin="16,0"
                    Visibility="Collapsed"/>
            
            <!-- 结果区 -->
            <Grid Grid.Row="2">
                <!-- 附件行 -->
                <views:AttachmentStrip x:Name="AttachmentStrip"
                                       DataContext="{Binding}"
                                       Margin="16,12,16,0"
                                       VerticalAlignment="Top"
                                       Visibility="{Binding Attachments.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                
                <!-- 面板切换区域 -->
                <ContentControl Content="{Binding CurrentPanel}"
                                Margin="0,12,0,0">
                    <ContentControl.Resources>
                        <!-- ChatPanel 作为默认内容 -->
                        <DataTemplate DataType="{x:Type vm:ChatPanelViewModel}">
                            <views:ChatPanel/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:HistoryPanelViewModel}">
                            <views:HistoryPanel/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:HelpPanelViewModel}">
                            <views:HelpPanel/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
                
                <!-- 默认消息列表（当 CurrentPanel 为 null 时显示） -->
                <ScrollViewer x:Name="MessageScroller"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16,0,16,16"
                              Visibility="{Binding CurrentPanel, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                    <views:ChatPanel x:Name="ChatPanel"
                                     DataContext="{Binding}"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>