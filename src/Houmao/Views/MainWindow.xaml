<Window x:Class="Houmao.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Houmao" 
        Width="600" 
        Height="48"
        WindowStartupLocation="Manual"
        Left="200"
        Top="200"
        WindowStyle="None"
        Background="#1E1E1E"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        IsVisibleChanged="Window_IsVisibleChanged"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border CornerRadius="24" 
            Background="#2D2D2D"
            BorderBrush="#404040"
            BorderThickness="1"
            Margin="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="6,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- 附件数量 -->
            <Border x:Name="AttachmentIndicator"
                    Grid.Column="0"
                    Width="28" Height="28"
                    CornerRadius="14"
                    Background="#1976D2"
                    Margin="4,0,4,0"
                    Visibility="{Binding Attachments.Count, Converter={StaticResource CountToVisibilityConverter}}"
                    Cursor="Hand"
                    MouseLeftButtonDown="AttachButton_Click">
                <TextBlock Text="{Binding Attachments.Count}" 
                           Foreground="White" FontSize="11" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            
            <!-- 输入框 -->
            <TextBox x:Name="InputTextBox"
                     Grid.Column="1"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#FFFFFF"
                     CaretBrush="#FFFFFF"
                     FontSize="15"
                     VerticalContentAlignment="Center"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="False"
                     KeyDown="InputTextBox_KeyDown"/>
            
            <!-- 发送按钮 -->
            <Border x:Name="SendButton"
                    Grid.Column="2"
                    Width="28" Height="28"
                    CornerRadius="14"
                    Background="#1976D2"
                    Margin="4,0,4,0"
                    Cursor="Hand"
                    MouseLeftButtonDown="SendButton_Click"
                    Visibility="Collapsed">
                <TextBlock Text="↑" Foreground="White" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>
