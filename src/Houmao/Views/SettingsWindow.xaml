<Window x:Class="Houmao.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings" 
        Width="600" 
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        KeyDown="Window_KeyDown">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题 -->
        <TextBlock Grid.Row="0" 
                   Text="Settings" 
                   FontSize="20" 
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>
        
        <!-- 设置内容 -->
        <TabControl Grid.Row="1">
            <!-- Provider 管理 -->
            <TabItem Header="Providers">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Provider 列表 -->
                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding Providers}"
                              SelectedItem="{Binding SelectedProvider}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="API URL" Binding="{Binding ApiUrl}" Width="2*"/>
                            <DataGridTextColumn Header="Models" Binding="{Binding Models, Converter={StaticResource ListToStringConverter}}" Width="2*"/>
                            <DataGridCheckBoxColumn Header="Default" Binding="{Binding IsDefault, Mode=OneWay}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Provider 操作按钮 -->
                    <StackPanel Grid.Row="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">
                        <Button Content="Add" 
                                Command="{Binding AddProviderCommand}"
                                Margin="0,0,10,0"/>
                        <Button Content="Edit" 
                                Command="{Binding EditProviderCommand}"
                                CommandParameter="{Binding SelectedProvider}"
                                IsEnabled="{Binding SelectedProvider, Converter={StaticResource NullToBoolConverter}}"
                                Margin="0,0,10,0"/>
                        <Button Content="Delete" 
                                Command="{Binding DeleteProviderCommand}"
                                CommandParameter="{Binding SelectedProvider}"
                                IsEnabled="{Binding SelectedProvider, Converter={StaticResource NullToBoolConverter}}"
                                Margin="0,0,10,0"/>
                        <Button Content="Set Default" 
                                Command="{Binding SetDefaultProviderCommand}"
                                CommandParameter="{Binding SelectedProvider}"
                                IsEnabled="{Binding SelectedProvider, Converter={StaticResource NullToBoolConverter}}"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- Provider 编辑 -->
            <TabItem Header="Edit Provider">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Provider Name" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="1" 
                             Text="{Binding EditingProvider.Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,15"/>
                    
                    <TextBlock Grid.Row="2" Text="API URL" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="3" 
                             Text="{Binding EditingProvider.ApiUrl, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,15"/>
                    
                    <TextBlock Grid.Row="4" Text="Models (comma separated)" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="5" 
                             Text="{Binding EditingProvider.ModelsText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Margin="0,0,0,15"/>
                    
                    <TextBlock Grid.Row="6" Text="API Key" Margin="0,0,0,5"/>
                    <PasswordBox Grid.Row="7" 
                                 x:Name="ApiKeyPasswordBox"
                                 PasswordChanged="ApiKeyPasswordBox_PasswordChanged"
                                 Margin="0,0,0,20"/>
                    
                    <StackPanel Grid.Row="8" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right">
                        <Button Content="Save" 
                                Command="{Binding SaveProviderCommand}"
                                Margin="0,0,10,0"/>
                        <Button Content="Cancel" 
                                Command="{Binding CancelEditCommand}"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- 通用设置 -->
            <TabItem Header="General">
                <StackPanel Margin="10">
                    <CheckBox Content="Start with Windows" 
                              IsChecked="{Binding StartWithWindows}"
                              Margin="0,0,0,10"/>
                    
                    <CheckBox Content="Copy on Selection" 
                              IsChecked="{Binding SelectToCopyEnabled}"
                              Margin="0,0,0,10"/>
                    
                    <CheckBox Content="Track Usage History" 
                              IsChecked="{Binding TrackUsageHistory}"
                              Margin="0,0,0,10"/>
                    
                    <CheckBox Content="Follow System Theme" 
                              IsChecked="{Binding FollowSystemTheme}"
                              Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Theme" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme}"
                              Width="200"
                              HorizontalAlignment="Left"
                              Margin="0,0,0,20"/>
                </StackPanel>
            </TabItem>
        </TabControl>
        
        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Save All" 
                    Command="{Binding SaveAllCommand}"
                    Margin="0,0,10,0"/>
            <Button Content="Close" 
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>