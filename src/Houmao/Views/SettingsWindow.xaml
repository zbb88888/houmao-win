<Window x:Class="Houmao.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings" 
        Width="560" 
        Height="Auto"
        MaxHeight="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        KeyDown="Window_KeyDown">
    
    <!-- 主容器：毛玻璃效果 -->
    <Border CornerRadius="10"
            Background="{DynamicResource Bg}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="0.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.18" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="24,16,20,12"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="{Binding InitialPage, StringFormat='{}{0} Settings', Converter={StaticResource StringTitleCaseConverter}}"
                           FontSize="15" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Text}"
                           VerticalAlignment="Center"/>
                
                <Button Grid.Column="1"
                        Content="✕"
                        Style="{DynamicResource WindowButtonStyle}"
                        Click="CloseButton_Click"/>
            </Grid>
            
            <!-- Providers 页面 -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,0,24,16"
                          Visibility="{Binding IsProvidersPage, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <!-- Provider 列表 -->
                    <ItemsControl ItemsSource="{Binding Providers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ProviderItem"
                                        Background="{Binding IsDefault, Converter={StaticResource DefaultToBackgroundConverter}}"
                                        CornerRadius="6"
                                        Padding="10,8"
                                        Margin="0,0,0,2"
                                        MouseEnter="ProviderItem_MouseEnter"
                                        MouseLeave="ProviderItem_MouseLeave">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- 默认标记 -->
                                        <Ellipse Grid.Column="0"
                                                 Width="6" Height="6"
                                                 Fill="{DynamicResource Accent}"
                                                 Margin="0,0,8,0"
                                                 Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        
                                        <!-- 名称和模型 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="13"
                                                       Foreground="{DynamicResource Text}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding ModelsSummary}" 
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <!-- 悬停操作按钮 -->
                                        <StackPanel Grid.Column="2" 
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Visibility="Collapsed"
                                                    x:Name="ActionsPanel">
                                            <Button Content="Default"
                                                    Style="{DynamicResource ButtonStyle}"
                                                    FontSize="11"
                                                    Padding="6,2"
                                                    Command="{Binding DataContext.SetDefaultProviderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Edit"
                                                    Style="{DynamicResource ButtonStyle}"
                                                    FontSize="11"
                                                    Padding="6,2"
                                                    Command="{Binding DataContext.EditProviderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Delete"
                                                    Style="{DynamicResource ButtonStyle}"
                                                    FontSize="11"
                                                    Padding="6,2"
                                                    Foreground="{DynamicResource TextSecondary}"
                                                    Command="{Binding DataContext.DeleteProviderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- 添加 Provider 按钮 -->
                    <Button Content="+ Add provider"
                            Style="{DynamicResource ButtonStyle}"
                            FontSize="12"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,0"
                            Command="{Binding AddProviderCommand}"/>
                    
                    <!-- 编辑 Provider 表单（就地展开） -->
                    <Border x:Name="EditProviderForm"
                            Background="{DynamicResource Surface}"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,12,0,0"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 左列 -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" 
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,4"/>
                            <TextBox Grid.Row="1" Grid.Column="0"
                                     Text="{Binding EditingProvider.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource InputStyle}"
                                     FontSize="13"
                                     Margin="0,0,0,8"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="API URL" 
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,4"/>
                            <TextBox Grid.Row="3" Grid.Column="0"
                                     Text="{Binding EditingProvider.ApiUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource InputStyle}"
                                     FontSize="13"
                                     Margin="0,0,0,8"/>
                            
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="API Key" 
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,4"/>
                            <PasswordBox Grid.Row="5" Grid.Column="0"
                                         x:Name="ApiKeyPasswordBox"
                                         Style="{DynamicResource PasswordBoxStyle}"
                                         PasswordChanged="ApiKeyPasswordBox_PasswordChanged"/>
                            
                            <!-- 右列 -->
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Models" 
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,4"/>
                            <TextBox Grid.Row="1" Grid.Column="2"
                                     Grid.RowSpan="4"
                                     Text="{Binding EditingProvider.ModelsText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource InputStyle}"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalAlignment="Stretch"/>
                            
                            <!-- 按钮行 -->
                            <StackPanel Grid.Row="5" Grid.Column="2" 
                                        Orientation="Horizontal" 
                                        HorizontalAlignment="Right"
                                        Margin="0,8,0,0">
                                <Button Content="Save" 
                                        Style="{DynamicResource AccentButtonStyle}"
                                        FontSize="12"
                                        Padding="12,4"
                                        Command="{Binding SaveProviderCommand}"
                                        Margin="0,0,8,0"/>
                                <Button Content="Cancel" 
                                        Style="{DynamicResource ButtonStyle}"
                                        FontSize="12"
                                        Padding="12,4"
                                        Command="{Binding CancelEditCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- General 页面 -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,0,24,16"
                          Visibility="{Binding IsGeneralPage, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <!-- 开关选项 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                   Text="Start with Windows"
                                   FontSize="13"
                                   Foreground="{DynamicResource Text}"
                                   VerticalAlignment="Center"/>
                        
                        <ToggleButton Grid.Column="1"
                                      Style="{DynamicResource ToggleSwitchStyle}"
                                      IsChecked="{Binding StartWithWindows}"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                   Text="Copy on selection"
                                   FontSize="13"
                                   Foreground="{DynamicResource Text}"
                                   VerticalAlignment="Center"/>
                        
                        <ToggleButton Grid.Column="1"
                                      Style="{DynamicResource ToggleSwitchStyle}"
                                      IsChecked="{Binding SelectToCopyEnabled}"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                   Text="Track usage history"
                                   FontSize="13"
                                   Foreground="{DynamicResource Text}"
                                   VerticalAlignment="Center"/>
                        
                        <ToggleButton Grid.Column="1"
                                      Style="{DynamicResource ToggleSwitchStyle}"
                                      IsChecked="{Binding TrackUsageHistory}"/>
                    </Grid>
                    
                    <!-- 主题选择 -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                   Text="Theme"
                                   FontSize="13"
                                   Foreground="{DynamicResource Text}"
                                   VerticalAlignment="Center"/>
                        
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ThemeOptions}"
                                  SelectedItem="{Binding SelectedTheme}"
                                  Style="{DynamicResource ComboBoxStyle}"
                                  Width="120"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>