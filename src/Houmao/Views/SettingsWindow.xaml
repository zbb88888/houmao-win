<Window x:Class="Houmao.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings" 
        Width="480" 
        Height="Auto"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        KeyDown="Window_KeyDown">
    
    <!-- 主容器：毛玻璃效果 -->
    <Border CornerRadius="10"
            Background="{DynamicResource Bg}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="0.5">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.18" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="20,16,16,16"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="Settings" 
                           FontSize="15" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Text}"
                           VerticalAlignment="Center"/>
                
                <Button Grid.Column="1"
                        Content="✕"
                        Style="{DynamicResource WindowButtonStyle}"
                        Click="CloseButton_Click"/>
            </Grid>
            
            <!-- 内容区 -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,0,20,20">
                <StackPanel>
                    <!-- PROVIDERS 部分 -->
                    <TextBlock Text="PROVIDERS" 
                               FontSize="12" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,12"/>
                    
                    <!-- Provider 列表 -->
                    <ItemsControl ItemsSource="{Binding Providers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ProviderItem"
                                        Background="{Binding IsDefault, Converter={StaticResource DefaultToBackgroundConverter}}"
                                        CornerRadius="6"
                                        Padding="12,10"
                                        Margin="0,0,0,4"
                                        MouseEnter="ProviderItem_MouseEnter"
                                        MouseLeave="ProviderItem_MouseLeave">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- 默认标记 -->
                                        <Ellipse Grid.Column="0"
                                                 Width="8" Height="8"
                                                 Fill="{DynamicResource TextSecondary}"
                                                 Margin="0,0,10,0"
                                                 Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        
                                        <!-- 名称和模型 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="14"
                                                       Foreground="{DynamicResource Text}"/>
                                            <TextBlock Text="{Binding ModelsSummary}" 
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        
                                        <!-- 悬停操作按钮 -->
                                        <StackPanel Grid.Column="2" 
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Visibility="Collapsed"
                                                    x:Name="ActionsPanel">
                                            <Button Content="Set default"
                                                    Style="{DynamicResource ButtonStyle}"
                                                    FontSize="12"
                                                    Padding="6,4"
                                                    Command="{Binding DataContext.SetDefaultProviderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Edit"
                                                    Style="{DynamicResource ButtonStyle}"
                                                    FontSize="12"
                                                    Padding="6,4"
                                                    Command="{Binding DataContext.EditProviderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Delete"
                                                    Style="{DynamicResource ButtonStyle}"
                                                    FontSize="12"
                                                    Padding="6,4"
                                                    Foreground="{DynamicResource TextSecondary}"
                                                    Command="{Binding DataContext.DeleteProviderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- 添加 Provider 按钮 -->
                    <Button Content="+ Add provider"
                            Style="{DynamicResource ButtonStyle}"
                            FontSize="13"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,20"
                            Command="{Binding AddProviderCommand}"/>
                    
                    <!-- 编辑 Provider 表单（就地展开） -->
                    <Border x:Name="EditProviderForm"
                            Background="{DynamicResource Surface}"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,0,0,20"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Provider Name" 
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditingProvider.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource InputStyle}"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>
                            
                            <TextBlock Text="API URL" 
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditingProvider.ApiUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource InputStyle}"
                                     FontSize="14"
                                     Margin="0,0,0,12"/>
                            
                            <TextBlock Text="Models (comma separated)" 
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditingProvider.ModelsText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource InputStyle}"
                                     FontSize="14"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Margin="0,0,0,12"/>
                            
                            <TextBlock Text="API Key" 
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,0,0,4"/>
                            <PasswordBox x:Name="ApiKeyPasswordBox"
                                         Style="{DynamicResource PasswordBoxStyle}"
                                         PasswordChanged="ApiKeyPasswordBox_PasswordChanged"
                                         Margin="0,0,0,16"/>
                            
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Right">
                                <Button Content="Save" 
                                        Style="{DynamicResource AccentButtonStyle}"
                                        Command="{Binding SaveProviderCommand}"
                                        Margin="0,0,8,0"/>
                                <Button Content="Cancel" 
                                        Style="{DynamicResource ButtonStyle}"
                                        Command="{Binding CancelEditCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- GENERAL 部分 -->
                    <TextBlock Text="GENERAL" 
                               FontSize="12" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,12"/>
                    
                    <!-- 开关选项 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                   Text="Start with Windows"
                                   FontSize="14"
                                   Foreground="{DynamicResource Text}"
                                   VerticalAlignment="Center"/>
                        
                        <ToggleButton Grid.Column="1"
                                      Style="{DynamicResource ToggleSwitchStyle}"
                                      IsChecked="{Binding StartWithWindows}"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                   Text="Copy on selection"
                                   FontSize="14"
                                   Foreground="{DynamicResource Text}"
                                   VerticalAlignment="Center"/>
                        
                        <ToggleButton Grid.Column="1"
                                      Style="{DynamicResource ToggleSwitchStyle}"
                                      IsChecked="{Binding SelectToCopyEnabled}"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                   Text="Track usage history"
                                   FontSize="14"
                                   Foreground="{DynamicResource Text}"
                                   VerticalAlignment="Center"/>
                        
                        <ToggleButton Grid.Column="1"
                                      Style="{DynamicResource ToggleSwitchStyle}"
                                      IsChecked="{Binding TrackUsageHistory}"/>
                    </Grid>
                    
                    <!-- 主题选择 -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                   Text="Theme"
                                   FontSize="14"
                                   Foreground="{DynamicResource Text}"
                                   VerticalAlignment="Center"/>
                        
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding ThemeOptions}"
                                  SelectedItem="{Binding SelectedTheme}"
                                  Style="{DynamicResource ComboBoxStyle}"
                                  Width="120"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>